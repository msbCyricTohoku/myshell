#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/wait.h>
#include <unistd.h>

#define MAX_LINE 1024
#define MAX_ARGS 64

int main() {
  char line[MAX_LINE];
  char *args[MAX_ARGS];

  // The Infinite Shell Loop
  while (1) {
    printf("myshell> ");

    // 1. READ
    if (!fgets(line, MAX_LINE, stdin)) {
      break; // Exit on EOF (Ctrl+D)
    }

    // Strip the trailing newline character
    line[strcspn(line, "\n")] = 0;

    // 2. PARSE
    int i = 0;
    char *token = strtok(line, " ");
    while (token != NULL) {
      args[i++] = token;
      token = strtok(NULL, " ");
    }
    args[i] = NULL; // execvp requires a null-terminated array

    // If the user just hit Enter, loop again
    if (args[0] == NULL) {
      continue;
    }

    // --- BUILT-IN COMMANDS ---
    if (strcmp(args[0], "exit") == 0) {
      break; // Break the loop to close the shell
    }

    if (strcmp(args[0], "cd") == 0) {
      if (args[1] == NULL) {
        fprintf(stderr, "myshell: expected argument to \"cd\"\n");
      } else {
        if (chdir(args[1]) != 0) {
          perror("myshell");
        }
      }
      continue; // Skip the fork/exec step for built-ins
    }

    // 3. EXECUTE
    pid_t pid = fork();

    if (pid == 0) {
      // Child Process: This is where the command actually runs
      if (execvp(args[0], args) == -1) {
        perror("myshell"); // Prints error if command isn't found
      }
      exit(EXIT_FAILURE);
    } else if (pid < 0) {
      // Error forking
      perror("myshell");
    } else {
      // Parent Process (The Shell): Wait for the child to finish
      waitpid(pid, NULL, 0);
    }
  }

  return 0;
}
